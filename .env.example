############################
# OmniVoice OpenAI-compatible API
############################

MODEL_ID=k2-fsa/OmniVoice

HOST=0.0.0.0
PORT=8091

############################
# Auth
############################

API_KEY=change-me

############################
# GPU
############################

CUDA_VISIBLE_DEVICES=0

# Conservative default. Increase on H100 if stable.
GPU_MEMORY_UTILIZATION=0.50

# Usually enough for TTS input.
MAX_MODEL_LEN=4096

# H100 / DGX Spark safe default.
DTYPE=float16

############################
# Cache
############################

HF_HOME=./.cache/huggingface

############################
# Optional/default
############################

# TRUST_REMOTE_CODE=1
# TOKENIZERS_PARALLELISM=false
# HF_HUB_ENABLE_HF_TRANSFER=1

############################
# Install-time overrides
############################

# PYTHON_VERSION=3.12

# Keep this pair aligned.
# vLLM-Omni v0.19.0rc1 is aligned with vLLM 0.19.0.
# VLLM_VERSION=0.19.0
# VLLM_CUDA_TAG=auto  # auto, default, or cu130
# VLLM_OMNI_GIT_REF=v0.19.0rc1
